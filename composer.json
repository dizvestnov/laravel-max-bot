{
    "name": "dizvestnov/laravel-max-bot",
    "description": "Laravel package for MAX messenger Bot API",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "max", "messenger", "bot", "chatbot", "api"],
    "authors": [
        {
            "name": "Dmitrii Tararaev",
            "email": "ivestarator@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "illuminate/support": "^8.0|^9.0",
        "illuminate/http": "^8.0|^9.0",
        "illuminate/console": "^8.0|^9.0",
        "illuminate/queue": "^8.0|^9.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.47|^7.0",
        "phpunit/phpunit": "^9.6 <10",
        "mockery/mockery": "^1.4",
        "friendsofphp/php-cs-fixer": "^3.59,<3.65",
        "phpstan/phpstan": "^1.10|^2.0",
        "nunomaduro/larastan": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "Dizvestnov\\LaravelMaxBot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dizvestnov\\LaravelMaxBot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dizvestnov\\LaravelMaxBot\\MaxBotServiceProvider"
            ],
            "aliases": {
                "MaxBot": "Dizvestnov\\LaravelMaxBot\\Facades\\MaxBot"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
