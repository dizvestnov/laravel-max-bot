{
    "name": "dizvestnov/laravel-max-bot",
    "description": "Laravel package for MAX messenger Bot API",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "max", "messenger", "bot", "chatbot", "api"],
    "authors": [
        {
            "name": "Dmitry Dizvestnov",
            "email": "dizvestnov@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/queue": "^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.4"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0",
        "nunomaduro/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Dizvestnov\\LaravelMaxBot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dizvestnov\\LaravelMaxBot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dizvestnov\\LaravelMaxBot\\MaxBotServiceProvider"
            ],
            "aliases": {
                "MaxBot": "Dizvestnov\\LaravelMaxBot\\Facades\\MaxBot"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
